# ==============================================================================
# StremHU Source - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' or '.env.local' to configure your local environment.
# Real environment variables (e.g. from docker-compose) automatically override
# any values set in .env files.
# ==============================================================================

# Node Environment Mode (production / development / test)
# ------------------------------------------------------------------------------
NODE_ENV=production

# FastAPI Server Port
# ------------------------------------------------------------------------------
PORT=4300

# Libtorrent Listening Port
# ------------------------------------------------------------------------------
LIBTORRENT_PORT=6881

# Cryptographic Session Signatures Key
# ------------------------------------------------------------------------------
# Highly recommended to change this to a secure random string in production!
SESSION_SECRET=stremhu-source

# StremHU Catalog URL
# ------------------------------------------------------------------------------
STREMHU_CATALOG_URL=https://catalog.stremhu.app
